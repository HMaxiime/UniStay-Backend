generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}
// ─── ENUMS ───────────────────────────────────────────

enum Role {
  STUDENT
  HOST
  EMPLOYER
  ADMIN
}

enum VerificationStatus {
  PENDING
  VERIFIED
  REJECTED
}

enum ApplicationStatus {
  PENDING
  ACCEPTED
  REJECTED
}

enum ScheduleType {
  FULL_TIME
  PART_TIME
  INTERNSHIP
}

enum SkillLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
}

enum MaterialType {
  VIDEO
  PDF
  ARTICLE
  QUIZ
}

enum AssignmentStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
}

// ─── MODELS ──────────────────────────────────────────


 model User {
  id                 String    @id @default(uuid())
  fullName           String
  email              String    @unique
  phone              String?
  password           String
  role               Role      @default(STUDENT)
  location           String?
  profilePicture     String?
  resetToken         String?
  resetTokenExpiry   DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  housings          Housing[]
  jobs              Job[]
  applications      Application[]
  userSkills        UserSkill[]
  bookings          Booking[]
  assignmentResults AssignmentResult[]
}

model Housing {
  id                 String             @id @default(uuid())
  title              String
  location           String
  price              Float
  availability       Boolean            @default(true)
  verificationStatus VerificationStatus @default(PENDING)
  hostId             String
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  host     User      @relation(fields: [hostId], references: [id])
  bookings Booking[]
}

model Job {
  id           String       @id @default(uuid())
  title        String
  location     String
  salary       Float
  scheduleType ScheduleType
  employerId   String
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  employer     User          @relation(fields: [employerId], references: [id])
  applications Application[]
  jobSkills    JobSkill[]
}

model Skill {
  id       String     @id @default(uuid())
  name     String
  category String
  level    SkillLevel

  userSkills  UserSkill[]
  jobSkills   JobSkill[]
  materials   MaterialSkill[]
  assignments Assignment[]
}

model UserSkill {
  id               String   @id @default(uuid())
  userId           String
  skillId          String
  completionStatus Boolean  @default(false)
  createdAt        DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id])
  skill Skill @relation(fields: [skillId], references: [id])
}

model JobSkill {
  id      String @id @default(uuid())
  jobId   String
  skillId String

  job   Job   @relation(fields: [jobId], references: [id])
  skill Skill @relation(fields: [skillId], references: [id])
}

model Application {
  id        String            @id @default(uuid())
  userId    String
  jobId     String
  status    ApplicationStatus @default(PENDING)
  createdAt DateTime          @default(now())

  user User @relation(fields: [userId], references: [id])
  job  Job  @relation(fields: [jobId], references: [id])
}

model Booking {
  id        String        @id @default(uuid())
  userId    String
  housingId String
  status    BookingStatus @default(PENDING)
  checkIn   DateTime
  checkOut  DateTime
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  user    User    @relation(fields: [userId], references: [id])
  housing Housing @relation(fields: [housingId], references: [id])
}

// ─── LEARNING MATERIALS ──────────────────────────────

// A learning resource uploaded by an admin (video, PDF, article, etc.)
model Material {
  id          String       @id @default(uuid())
  title       String
  description String?
  type        MaterialType
  url         String                // file URL or link
  uploadedBy  String                // admin user id
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  skills      MaterialSkill[]
  assignments Assignment[]
}

// Many-to-many: which skills a material covers
model MaterialSkill {
  id         String @id @default(uuid())
  materialId String
  skillId    String

  material Material @relation(fields: [materialId], references: [id])
  skill    Skill    @relation(fields: [skillId], references: [id])
}

// An assignment = a quiz attached to a material.
// Admin sets how many questions the student must answer (questionCount),
// but can upload many more questions into the Question pool.
model Assignment {
  id            String   @id @default(uuid())
  title         String
  materialId    String               // the material this quiz is attached to
  skillId       String               // the skill this assignment trains
  questionCount Int                  // how many questions the student sees per attempt
  passingScore  Int      @default(70) // minimum % to pass
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  material  Material           @relation(fields: [materialId], references: [id])
  skill     Skill              @relation(fields: [skillId], references: [id])
  questions Question[]
  results   AssignmentResult[]
}

// A single question in the question pool for an assignment.
// Admin can add as many as they want; students only see `questionCount` of them.
model Question {
  id           String   @id @default(uuid())
  assignmentId String
  text         String   // the question text
  createdAt    DateTime @default(now())

  assignment Assignment @relation(fields: [assignmentId], references: [id])
  options    Option[]
  answers    StudentAnswer[]
}

// One of the 4 answer choices for a question
model Option {
  id         String  @id @default(uuid())
  questionId String
  text       String  // option label/text
  isCorrect  Boolean @default(false)

  question      Question        @relation(fields: [questionId], references: [id])
  studentAnswers StudentAnswer[]
}

// Tracks a student's full attempt at an assignment
model AssignmentResult {
  id           String           @id @default(uuid())
  userId       String
  assignmentId String
  score        Int              // percentage score (0-100)
  status       AssignmentStatus @default(NOT_STARTED)
  startedAt    DateTime         @default(now())
  completedAt  DateTime?

  user        User            @relation(fields: [userId], references: [id])
  assignment  Assignment      @relation(fields: [assignmentId], references: [id])
  answers     StudentAnswer[]
}

// Records which option the student picked for each question in their attempt
model StudentAnswer {
  id                 String @id @default(uuid())
  assignmentResultId String
  questionId         String
  selectedOptionId   String

  assignmentResult AssignmentResult @relation(fields: [assignmentResultId], references: [id])
  question         Question         @relation(fields: [questionId], references: [id])
  selectedOption   Option           @relation(fields: [selectedOptionId], references: [id])
}